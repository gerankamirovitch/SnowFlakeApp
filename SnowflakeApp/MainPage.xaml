<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="SnowflakeApp.MainPage"
             BackgroundColor="DarkBlue"
             Title="Akysaya">

    <Grid>
        <skia:SKCanvasView x:Name="SnowView" PaintSurface="OnSnowPaint" InputTransparent="True" />

        <Grid RowDefinitions="*, Auto" Padding="10">

            <Frame Grid.Row="0" BackgroundColor="#30FFFFFF" BorderColor="White" CornerRadius="20" Margin="10">
                <skia:SKCanvasView x:Name="SnowflakeView" PaintSurface="OnSnowflakePaint" />
            </Frame>

            <VerticalStackLayout Grid.Row="1" Spacing="10" BackgroundColor="#80000000" Padding="15" RadioButton.CornerRadius="15">

                <Label Text="Сложность узора" TextColor="White" FontAttributes="Bold"/>
                <Slider x:Name="SliderComplexity" Minimum="1" Maximum="6" Value="3" ValueChanged="OnSliderChanged" ThumbColor="Red" MinimumTrackColor="Red"/>

                <Label Text="Пушистость (Угол)" TextColor="White" FontAttributes="Bold"/>
                <Slider x:Name="SliderAngle" Minimum="20" Maximum="90" Value="45" ValueChanged="OnSliderChanged" ThumbColor="Green" MinimumTrackColor="Green"/>

                <Grid ColumnDefinitions="*,*">
                    <Button Text="В галерею" Clicked="OnSaveClicked" BackgroundColor="#008000" TextColor="White" Margin="5"/>
                    <Button Text="Печать (PDF)" Clicked="OnPrintClicked" BackgroundColor="#D42426" TextColor="White" Margin="5"/>
                </Grid>

                <Button Text="Перейти в Галерею ->" Clicked="OnGoToGalleryClicked" BackgroundColor="Transparent" TextColor="White"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>